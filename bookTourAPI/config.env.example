PORT=4000
NODE_ENV=development
DATABASE_PASSWORD=your_database_password
DATABASE_CONNECTION_STRING=mongodb+srv://<USERNAME>:<PASSWORD>@cluster0.xxxxxxx.mongodb.net/<DB_NAME>?appName=Cluster0

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=90d

# Email (example using Mailtrap for dev)
EMAIL_HOST=smtp.mailtrap.io
EMAIL_PORT=2525
EMAIL_USERNAME=your_mailtrap_username
EMAIL_PASSWORD=your_mailtrap_password
EMAIL_FROM=noreply@booktourapp.com
